# ============================================================
# AI Freight Load Acquisition System — Environment Variables
# ============================================================

# Server
PORT=3001
NODE_ENV=development
API_SECRET=your_api_secret_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# SendGrid (Email Sending)
SENDGRID_API_KEY=SG.your_key_here
FROM_EMAIL=freight@yourbrokerage.com
FROM_NAME=Your Freight Brokerage

# Twilio (SMS Notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15555550100

# User Notification Settings
NOTIFICATION_EMAIL=you@youremail.com
NOTIFICATION_PHONE=+15555551234

# Apollo.io (Contact Discovery)
APOLLO_API_KEY=your_apollo_key_here

# Hunter.io (Email Finder)
HUNTER_API_KEY=your_hunter_key_here

# Google Places API (Shipper Discovery)
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Redis (Queue)
REDIS_URL=redis://localhost:6379

# Gmail (Inbound Reply Monitoring — OAuth2)
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_USER=freight@yourbrokerage.com

# Rate Limits
DAILY_EMAIL_LIMIT=1000
FOLLOWUP_DELAY_DAYS=3
MAX_FOLLOWUPS=2

# Webhook (SendGrid inbound parse webhook secret)
SENDGRID_WEBHOOK_SECRET=your_webhook_secret
